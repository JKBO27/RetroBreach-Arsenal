<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>RBreach Weapons Terminal</title>

<style>

@font-face{
font-family:"retro";
src:url("retro.ttf");
}

body{
font-family:"retro";
margin:40px;
color:white;

background:linear-gradient(
to bottom,
#000000,
#0a0000,
#220000,
#400000
);

background-attachment:fixed;
min-height:100vh;
overflow-x:hidden;
}

body::after{
content:"";
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
pointer-events:none;

background:repeating-linear-gradient(
to bottom,
rgba(0,0,0,0.4) 0px,
rgba(0,0,0,0.4) 2px,
transparent 2px,
transparent 4px
);

opacity:0.35;
}

h1{
text-align:center;
letter-spacing:4px;
text-shadow:0 0 8px red;
}

.category{
margin-top:40px;
}

.category h2{
border-bottom:2px solid red;
padding-bottom:5px;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fill,minmax(250px,1fr));
gap:20px;
margin-top:20px;
}

.weapon{
background:#00000080;
padding:16px;
box-shadow:0 0 0 2px red;
}

.weapon h3{
margin-top:0;
text-shadow:0 0 6px red;
}

.stat{
font-size:14px;
margin-top:4px;
}

</style>

</head>

<body>

<h1>RBREACH WEAPONS TERMINAL</h1>

<div id="content"></div>

<script>

fetch("armas.txt")
.then(r=>r.text())
.then(text=>{

parseTXT(text)

})

function parseTXT(text){

let lines=text.split("\n")

let currentCategory=null
let currentWeapon=null

let categories={}

lines.forEach(raw=>{

let line=raw.trim()

if(line==="") return

// detectar categoria
if(line==="PISTOLAS" || line==="SMG" || line==="RIFLES" || line==="LMG" || line==="ESCOPETAS"){

currentCategory=line

if(!categories[currentCategory]){
categories[currentCategory]=[]
}

return

}

// detectar arma
if(line.startsWith("- ")){

if(currentWeapon && currentCategory){
categories[currentCategory].push(currentWeapon)
}

currentWeapon={
name:line.replace("- ",""),
stats:[]
}

return
}

// stats
if(currentWeapon){
currentWeapon.stats.push(line)
}

})

if(currentWeapon && currentCategory){
categories[currentCategory].push(currentWeapon)
}

render(categories)

}

function render(categories){

let container=document.getElementById("content")

Object.keys(categories).forEach(cat=>{

let section=document.createElement("div")
section.className="category"

let title=document.createElement("h2")
title.textContent=cat

let grid=document.createElement("div")
grid.className="grid"

categories[cat].forEach(weapon=>{

let card=document.createElement("div")
card.className="weapon"

let html="<h3>"+weapon.name+"</h3>"

weapon.stats.forEach(s=>{
html+="<div class='stat'>"+s+"</div>"
})

card.innerHTML=html

grid.appendChild(card)

})

section.appendChild(title)
section.appendChild(grid)

container.appendChild(section)

})

}

</script>

</body>
</html>
